# Generated by Cargo
# will have compiled files and executables
/target/
# Remove Cargo.lock from gitignore if you may have multiple binaries
# or want to ensure correct dependency versions
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds produce these
*.pdb

# SQLite databases (runtime/test artifacts, should not be committed)
*.db
*.db-shm
*.db-wal
*.db.backup

# Log files
*.log 